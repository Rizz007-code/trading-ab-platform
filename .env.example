# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_pass
POSTGRES_DB=trading_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full URL (auto-built by connection.py from above values, but can override)
DATABASE_URL=postgresql://trading_user:trading_pass@localhost:5432/trading_db

# ─── Tickers ──────────────────────────────────────────────────────────────────
# Comma-separated list of stock tickers to track
TICKERS=AAPL,MSFT,GOOGL,TSLA,AMZN,NVDA
INDEX_TICKERS=SPY,QQQ,DIA
SECTOR_TICKERS=XLK,XLF,XLE,XLV

# ─── Data Settings ────────────────────────────────────────────────────────────
# How many years of historical data to load on first run
HISTORICAL_YEARS=3
# Daily fetch window (days to look back for incremental load)
INCREMENTAL_DAYS=5

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=trading_strategy_selection

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ─── Dashboard ────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://trading_user:trading_pass@localhost:5432/airflow_db
AIRFLOW__CORE__LOAD_EXAMPLES=False
